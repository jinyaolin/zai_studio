# ─── AI Provider (zai) ─────────────────────────────────────────────
# OpenAI-compatible endpoint. Swap ZAI_BASE_URL / ZAI_MODEL to change providers.
ZAI_BASE_URL=https://api.openai.com/v1
ZAI_API_KEY=sk-your-key-here
ZAI_MODEL=gpt-4o-mini

# z.ai GLM-5.x only: set to "true" to disable reasoning_content (faster TTFT,
# ~26% speedup measured, at the cost of some quality on complex prompts).
ZAI_DISABLE_THINKING=false

# ─── TTS Provider ──────────────────────────────────────────────────
# Two providers supported:
#   edge  — FREE, Azure-powered, no API key needed. Good Chinese voices.
#           Voice options: zh-TW-HsiaoChenNeural / zh-TW-YunJheNeural (Taiwan)
#                          zh-CN-XiaoxiaoNeural / zh-CN-YunxiNeural   (Mainland)
#   openai — OpenAI-compatible. Needs TTS_API_KEY.
TTS_PROVIDER=edge
TTS_VOICE=zh-TW-HsiaoChenNeural
# Only used when TTS_PROVIDER=cosyvoice (start Python server first):
#   cd ~/dev/CosyVoice && source venv/bin/activate && python server.py
COSYVOICE_BASE_URL=http://127.0.0.1:9880
COSYVOICE_SPEED=1.0
# Optional: a different voice for dialogue chunks (lines that look like
# quoted speech). Leave commented to use one voice for everything.
# TTS_DIALOGUE_VOICE=zh-TW-YunJheNeural
# Prosody enhancement (rate/pitch tuned per chunk: narration slow, action
# fast, dialogue neutral, questions lift). Set to "false" to disable.
TTS_SSML_ENHANCEMENT=true
# Only used when TTS_PROVIDER=openai:
TTS_BASE_URL=https://api.openai.com/v1
TTS_API_KEY=sk-your-key-here
TTS_MODEL=tts-1

# ─── Auth ──────────────────────────────────────────────────────────
# Password protecting /studio/* and /api/ai/*, /api/tts/*.
# Generate one with: openssl rand -base64 32
AUTH_PASSWORD=change-me
AUTH_COOKIE_SECRET=also-change-me-please
# Master key for encrypting stored Google OAuth tokens (AES-256-GCM).
# Generate with: openssl rand -hex 32
# MUST be set in production. If unset in dev, falls back to a deterministic
# dev-only key (NOT safe for production).
AUTH_SECRET=change-me-too

# ─── Google OAuth (optional — enables "Sign in with Google" for Gemini) ───
# When all three are set, /studio/settings shows a "連線 Google" button.
# After the user connects, they can switch the active AI provider to Gemini
# (gemini-2.5-pro default, override with GEMINI_MODEL).
#
# Setup (one-time, ~5 min):
# 1. https://console.cloud.google.com/ → create or pick a project
# 2. APIs & Services → Enable "Generative Language API"
# 3. APIs & Services → OAuth consent screen
#      - User type: External
#      - Add scope: userinfo.email + Generative Language API (retriever)
#      - Add yourself to "Test users" (or publish the app)
# 4. APIs & Services → Credentials → Create OAuth Client (Web application)
#      - Authorized redirect URI: http://localhost:3100/api/auth/google/callback
#        (and your prod URL when deployed)
# 5. Copy Client ID + Client Secret here:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3100/api/auth/google/callback
# Optional: override the default Gemini model (gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.5-flash

# ─── Storage ───────────────────────────────────────────────────────
# Absolute or relative path; defaults to ./data/index.db if unset
# SQLITE_PATH=./data/index.db
